# Environment variables template for docker-compose.
# Copy this file to "docker/.env" and fill in the real values.
# The real .env file is gitignored: it must NEVER be committed.
#
#   cp docker/.env.example docker/.env
#
# Then edit docker/.env with your credentials and start with:
#   docker-compose up -d   (docker-compose loads ./.env automatically)

# --- Database ---
DB_PASSWORD=changeme

# --- Security ---
JWT_SECRET=replace-with-a-long-random-secret

# --- Mail (Gmail SMTP) ---
# The Gmail App Password (16 characters, NO spaces).
# Generate it at: Google Account > Security > App passwords.
MAIL_USERNAME=noreply.shopventory@gmail.com
MAIL_PASSWORD=your-gmail-app-password

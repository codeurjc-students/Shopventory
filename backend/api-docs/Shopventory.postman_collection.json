            "description": "Inicia sesión con un usuario sin rol de administrador (user@shopventory.com / User1234!). Útil para comprobar las restricciones 403 de los endpoints solo-admin."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login correcto (200)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Cookies de sesión recibidas\", function () {",
                  "    pm.expect(pm.cookies.has(\"AuthToken\")).to.be.true;",
                  "});",
                  "console.log('Sesion iniciada. Postman usara las cookies automaticamente en el resto de peticiones.');"
                ]
              }
            }
          ]
        },

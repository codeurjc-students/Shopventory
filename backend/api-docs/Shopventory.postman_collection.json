        {
          "name": "Registrar nuevo usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "https://localhost:443/api/auth/register",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "443",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo.usuario@shopventory.com\",\n  \"password\": \"Nuevo1234!\",\n  \"name\": \"Nuevo\",\n  \"surname\": \"Usuario\",\n  \"phone\": \"+34 600 123 456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Registra una cuenta nueva (queda pendiente de aprobación por un administrador). Guarda el id devuelto en la variable `createdUserId`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "    try {",
                  "        var data = pm.response.json();",
                  "        if (data && data.id !== undefined) {",
                  "            pm.collectionVariables.set(\"createdUserId\", data.id);",
                  "            console.log(\"Guardado createdUserId =\", data.id);",
                  "        }",
                  "    } catch (e) { /* respuesta sin cuerpo JSON */ }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
